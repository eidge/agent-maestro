exports[`HelpMenu snapshots layout: multiple groups with merged shortcuts 1`] = `
"







                   ╭─ Keyboard Shortcuts ───────────────────╮
                   │                                        │
                   │  General                               │
                   │  ?                     show help       │
                   │                                        │
                   │  Navigation                            │
                   │  Tab                   cycle panels    │
                   │                                        │
                   │  Diff                                  │
                   │  Shift+Up / Shift+k    previous block  │
                   │  gg                    scroll to top   │
                   │                                        │
                   │  Press ? or Escape to close            │
                   │                                        │
                   ╰────────────────────────────────────────╯"
`;

